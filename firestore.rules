rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUserProfile(data) {
      return data.keys().hasAll(['fullName', 'targetRole']) &&
             data.fullName is string && data.fullName.size() <= 200 &&
             data.targetRole is string && data.targetRole.size() <= 100 &&
             data.get('email', '') is string &&
             data.get('phone', '') is string &&
             data.get('collegeName', '') is string &&
             data.get('degree', '') is string &&
             data.get('year', '') is string &&
             data.get('updatedAt', '') is string;
    }

    function isValidAssessment(data) {
      return data.keys().hasAll(['userId', 'role', 'score']) &&
             data.userId == request.auth.uid &&
             data.role is string &&
             data.score is number;
    }

    // --- Rules ---

    match /users/{userId} {
      match /profile/main {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserProfile(incoming());
        allow update: if isOwner(userId) && isValidUserProfile(incoming()) && 
                        incoming().diff(existing()).affectedKeys().hasOnly([
                          'fullName', 'email', 'phone', 'gender', 'collegeName', 
                          'degree', 'specialization', 'year', 'targetRole', 
                          'userType', 'updatedAt'
                        ]);
      }

      match /assessments/{assessmentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(assessmentId) && isValidAssessment(incoming());
      }

      match /roadmaps/{roadmapId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(roadmapId);
      }
    }
    
    // --- Test Connection Block ---
    match /test/connection {
      allow read: if true;
    }
  }
}
